# Test Environment Configuration
NODE_ENV=test
PORT=3001
API_KEY=test-api-key-12345

# Test Database (use a separate test database)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/npl_convention_test?schema=public"

# Mock S3 Storage (these won't be used in tests as we mock the service)
S3_REGION=fr-par
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=test-bucket
S3_ACCESS_KEY_ID=test-access-key
S3_SECRET_ACCESS_KEY=test-secret-key

# Mock firma.dev
FIRMA_API_KEY=test-firma-api-key
FIRMA_API_URL=http://localhost:8080
FIRMA_WEBHOOK_SECRET=test-firma-webhook-secret

# Mock PayPlug
PAYPLUG_API_KEY=test-payplug-api-key
PAYPLUG_API_URL=http://localhost:8081
PAYPLUG_WEBHOOK_SECRET=test-payplug-webhook-secret

# Test URLs
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3002
