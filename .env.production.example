# Application
NODE_ENV=production
PORT=3000
API_KEY=your-secure-api-key-here

# Database (Hostinger MySQL ou PostgreSQL externe)
DATABASE_URL="postgresql://user:password@localhost:5432/npl_convention?schema=public"

# S3/Object Storage
S3_REGION=fr-par
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_BUCKET=npl-documents
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# firma.dev
FIRMA_API_KEY=your-firma-api-key
FIRMA_API_URL=https://api.firma.dev
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret

# PayPlug
PAYPLUG_API_KEY=your-payplug-api-key
PAYPLUG_API_URL=https://api.payplug.com
PAYPLUG_WEBHOOK_SECRET=your-payplug-webhook-secret

# Application URLs (remplacer par votre domaine)
APP_URL=https://api.votre-domaine.com
FRONTEND_URL=https://votre-domaine.com
