# Application
NODE_ENV=development
PORT=3000
API_KEY=your-internal-api-key-here

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/npl_convention?schema=public"

# S3/Object Storage (Scaleway, OVH, or other S3-compatible)
S3_REGION=fr-par
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_BUCKET=npl-documents
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# firma.dev
FIRMA_API_KEY=your-firma-api-key
FIRMA_API_URL=https://api.firma.dev
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret

# PayPlug
PAYPLUG_API_KEY=your-payplug-api-key
PAYPLUG_API_URL=https://api.payplug.com
PAYPLUG_WEBHOOK_SECRET=your-payplug-webhook-secret

# Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
