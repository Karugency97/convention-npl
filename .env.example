# Application
NODE_ENV=development
PORT=3000
API_KEY=your-internal-api-key-here

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/npl_convention?schema=public"

# Storage Mode: 'local' or 's3'
# Use 'local' for development (files stored in ./storage folder)
# Use 's3' for production with S3-compatible storage
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./storage

# S3/Object Storage (Scaleway, OVH, or other S3-compatible)
# Only used when STORAGE_MODE=s3
# Options: Scaleway, OVH, MinIO, Cloudflare R2, AWS S3
S3_REGION=fr-par
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_BUCKET=npl-documents
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# firma.dev
FIRMA_API_KEY=your-firma-api-key
FIRMA_API_URL=https://api.firma.dev
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret

# PayPlug
# TEST: sk_test_dFS49B82JJg753gB6nYBB
# LIVE: sk_live_3d8puKYBqYBE7kFsOiNFrq
PAYPLUG_API_KEY=sk_test_dFS49B82JJg753gB6nYBB
PAYPLUG_API_URL=https://api.payplug.com
PAYPLUG_WEBHOOK_SECRET=your-payplug-webhook-secret

# Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
